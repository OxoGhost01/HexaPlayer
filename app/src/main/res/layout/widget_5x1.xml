<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:orientation="horizontal"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Left: album art (square = widget height) -->
    <ImageView
        android:id="@+id/widget_album_art"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:adjustViewBounds="true"
        android:scaleType="centerCrop"
        android:background="@drawable/bg_widget_5x1_left"
        android:src="@drawable/ic_music_note"/>

    <!-- Right 2/3: song name (top) + controls (bottom) -->
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="2"
        android:background="@drawable/bg_widget_5x1_right">

        <!-- Top: song name -->
        <TextView
            android:id="@+id/widget_song_info"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:gravity="center_vertical"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="Not playing"/>

        <!-- Bottom: repeat | prev | play-pause | next | shuffle -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center">

            <ImageButton
                android:id="@+id/widget_repeat"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_repeat"
                android:background="@null"
                android:scaleType="fitCenter"/>

            <ImageButton
                android:id="@+id/widget_previous"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_skip_previous"
                android:background="@null"
                android:scaleType="fitCenter"/>

            <ImageButton
                android:id="@+id/widget_play_pause"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:src="@drawable/ic_play_arrow"
                android:background="@null"
                android:scaleType="fitCenter"/>

            <ImageButton
                android:id="@+id/widget_next"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_marginEnd="8dp"
                android:src="@drawable/ic_skip_next"
                android:background="@null"
                android:scaleType="fitCenter"/>

            <ImageButton
                android:id="@+id/widget_shuffle"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_shuffle"
                android:background="@null"
                android:scaleType="fitCenter"/>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
